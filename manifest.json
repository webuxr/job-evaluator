{
  "manifest_version": 3,
  "name": "Job Evaluator",
  "version": "0.1.2",
  "description": "Analyze the current job posting page for overall job quality signals using a local rule-based rubric.",
  "action": {
    "default_title": "Job Evaluator",
    "default_popup": "src/popup.html"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "options_page": "src/options.html",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
